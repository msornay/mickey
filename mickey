# --- State directories ---

MICKEY_DIR = Path.home() / ".mickey"
SSH_KEY = MICKEY_DIR / "ssh_key"
VMS_DIR = MICKEY_DIR / "vms"


def workspace() -> Path:
    return Path(os.environ.get("WORKSPACE_DIR", Path.home() / "src"))


# --- Rate limit guard (claude-guard) ---

GUARD_THRESHOLD_5H = 0.80
GUARD_THRESHOLD_7D = 0.80
GUARD_POLL_INTERVAL = 300  # seconds between rate limit checks
MESSAGES_URL = "https://api.anthropic.com/v1/messages"
KEYCHAIN_SERVICE = "Claude Code-credentials"


def _get_oauth_token():
    """Retrieve OAuth access token from macOS Keychain.

    Returns access_token or raises RuntimeError.
    """
    raw = subprocess.check_output(
        ["security", "find-generic-password", "-s", KEYCHAIN_SERVICE, "-w"],
        stderr=subprocess.DEVNULL,
        text=True,
    ).strip()
    creds = json.loads(raw)
    oauth = creds.get("claudeAiOauth")
    if not oauth or "accessToken" not in oauth:
        raise RuntimeError("Keychain JSON missing claudeAiOauth.accessToken")
    return oauth["accessToken"]


def _fetch_rate_limits(access_token):
    """Make a lightweight messages call and return (5h_util, 7d_util) floats.

    Returns (None, None) when headers are absent.
    """
    body = json.dumps(
        {
            "model": "claude-sonnet-4-20250514",
            "messages": [{"role": "user", "content": "hi"}],
            "max_tokens": 1,
        }
    ).encode()

    req = Request(MESSAGES_URL, data=body, method="POST")
    req.add_header("Authorization", f"Bearer {access_token}")
    req.add_header("Content-Type", "application/json")
    req.add_header("anthropic-version", "2023-06-01")
    req.add_header("anthropic-beta", "oauth-2025-04-20")
    req.add_header("anthropic-dangerous-direct-browser-access", "true")

    resp = urlopen(req)
    headers = resp.headers

    def _float(name):
        v = headers.get(name)
        if v is None:
            return None
        try:
            return float(v)
        except ValueError:
            return None

    return (
        _float("anthropic-ratelimit-unified-5h-utilization"),
        _float("anthropic-ratelimit-unified-7d-utilization"),
    )


def check_rate_limit():
    """Check whether we're rate-limited. Returns True if limited.

    Any error (network, auth, parsing) is treated as rate-limited per user
    instruction — claude-guard often errors out for weird reasons.
    """
    try:
        token = _get_oauth_token()
        util_5h, util_7d = _fetch_rate_limits(token)
        if util_5h is not None and util_5h >= GUARD_THRESHOLD_5H:
            print(f"\rguard: 5h utilization {util_5h:.0%} >= {GUARD_THRESHOLD_5H:.0%}")
            return True
        if util_7d is not None and util_7d >= GUARD_THRESHOLD_7D:
            print(f"\rguard: 7d utilization {util_7d:.0%} >= {GUARD_THRESHOLD_7D:.0%}")
            return True
        pct_5h = f"{util_5h:.0%}" if util_5h is not None else "?"
        pct_7d = f"{util_7d:.0%}" if util_7d is not None else "?"
        print(f"\rguard: ok (5h={pct_5h}, 7d={pct_7d})")
        return False
    except Exception as exc:
        print(f"\rguard: error ({exc}), treating as rate-limited")
        return True


# --- QEMU helpers ---


def ensure_mickey_dir():
    """Create ~/.mickey dir structure and SSH keypair if missing."""
    MICKEY_DIR.mkdir(exist_ok=True)
    VMS_DIR.mkdir(exist_ok=True)
    if not SSH_KEY.exists():
        subprocess.run(
            ["ssh-keygen", "-t", "ed25519", "-f", str(SSH_KEY), "-N", "", "-q"],
            check=True,
        )


def find_edk2_code() -> str:
    """Find the UEFI firmware file for aarch64."""
    candidates = [
        Path("/opt/homebrew/share/qemu/edk2-aarch64-code.fd"),
        Path("/usr/local/share/qemu/edk2-aarch64-code.fd"),
        Path("/usr/share/qemu/edk2-aarch64-code.fd"),
        Path("/usr/share/AAVMF/AAVMF_CODE.fd"),
    ]
    for c in candidates:
        if c.exists():
            return str(c)
    sys.exit("error: cannot find edk2-aarch64-code.fd. Install qemu: brew install qemu")


def allocate_port() -> int:
    """Find next free SSH port starting at 10022."""
    used = set()
    if VMS_DIR.is_dir():
        for port_file in VMS_DIR.glob("*/ssh_port"):
            try:
                used.add(int(port_file.read_text().strip()))
            except (ValueError, OSError):
                pass
    port = 10022
    while port in used:
        port += 1
    return port


def read_port(name: str) -> int:
    """Read SSH port for a VM."""
    return int((VMS_DIR / name / "ssh_port").read_text().strip())


def ssh_cmd(name: str, extra_ssh_args=None) -> list:
    """Build base SSH command for a VM."""
    port = read_port(name)
    cmd = [
        "ssh",
        "-o",
        "StrictHostKeyChecking=no",
        "-o",
        "UserKnownHostsFile=/dev/null",
        "-o",
        "LogLevel=ERROR",
        "-i",
        str(SSH_KEY),
        "-p",
        str(port),
    ]
    if extra_ssh_args:
        cmd.extend(extra_ssh_args)
    cmd.append("agent@localhost")
    return cmd


def start_vm(name: str):
    """Start a QEMU VM for the given agent."""
    vm_dir = VMS_DIR / name
    port = read_port(name)
    ram = os.environ.get("MICKEY_VM_RAM", "4096")
    cpus = os.environ.get("MICKEY_VM_CPUS", "2")
    edk2 = find_edk2_code()
    ws = str(workspace())

    cmd = [
        "qemu-system-aarch64",
        "-accel",
        "hvf",
        "-cpu",
        "host",
        "-M",
        "virt,highmem=on",
        "-m",
        ram,
        "-smp",
        cpus,
        "-drive",
        f"file={edk2},if=pflash,format=raw,readonly=on",
        "-drive",
        f"file={vm_dir}/vars.fd,if=pflash,format=raw",
        "-drive",
        f"if=virtio,file={vm_dir}/disk.qcow2,format=qcow2",
        "-netdev",
        f"user,id=net0,hostfwd=tcp::{port}-:22",
        "-device",
        "virtio-net-pci,netdev=net0",
        "-virtfs",
        f"local,path={ws},mount_tag=workspace,security_model=none",
        "-monitor",
        f"unix:{vm_dir}/monitor.sock,server,nowait",
        "-pidfile",
        f"{vm_dir}/pid",
        "-display",
        "none",
        "-serial",
        f"file:{vm_dir}/console.log",
        "-daemonize",
    ]
    subprocess.run(cmd, check=True)


def stop_vm(name: str):
    """Stop a QEMU VM via monitor socket, falling back to SIGKILL."""
    vm_dir = VMS_DIR / name
    monitor = vm_dir / "monitor.sock"
    pid_file = vm_dir / "pid"

    # Try clean shutdown via QEMU monitor
    if monitor.exists():
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.connect(str(monitor))
            s.sendall(b"system_powerdown\n")
            s.close()
        except OSError:
            pass

    # Wait up to 10s for process to exit
    if pid_file.exists():
        try:
            pid = int(pid_file.read_text().strip())
            for _ in range(20):
                try:
                    os.kill(pid, 0)
                    time.sleep(0.5)
                except ProcessLookupError:
                    return
            # Still alive after 10s — force kill
            os.kill(pid, signal.SIGKILL)
        except (ValueError, ProcessLookupError, OSError):
            pass


def wait_for_ssh(name: str, timeout: int = 120):
    """Poll until SSH is ready on the VM's port."""
    port = read_port(name)
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        try:
            s = socket.create_connection(("localhost", port), timeout=2)
            s.close()
            return
        except OSError:
            time.sleep(1)
    sys.exit(f"error: SSH not ready on port {port} after {timeout}s")


# --- Task selection ---


def pick_task(ws: Path):
    """Pick a task: 10% rules audit, 90% random from todos + one QA entry.

    The 90% pool lists all real todo files plus one synthetic "QA" entry,
    then picks randomly.  This means:
      - Many todos → QA is rare (1/(N+1))
      - No todos   → QA is guaranteed
      - Few todos  → QA gets a fair share

    Returns (wip_path_or_None, prompt_text, agent_type).
    Returns (None, None, None) when no task is available.
    """
    repos_dir = ws / "repos"
    repos = []
    if repos_dir.is_dir():
        repos = [
            p.name
            for p in repos_dir.iterdir()
            if p.is_dir() and not p.name.startswith(".")
        ]

    roll = random.randint(1, 10)

    # 10% chance: rules audit (roll == 1)
    if roll == 1 and repos:
        repo = random.choice(repos)
        return (
            None,
            (
                f"Rules audit: clone $WORKSPACE_DIR/repos/{repo} "
                f"into ~/work/{repo}. "
                "Read $WORKSPACE_DIR/RULES.md and the repo's own "
                "RULES.md (if any). "
                "Verify the repo follows the rules documented there. "
                "For each violation found, create a todo file in "
                "$WORKSPACE_DIR/todos/ describing the issue. "
                "Exit cleanly if everything is in order."
            ),
            "qa",
        )

    # 90% chance: random pick from todos + one synthetic QA entry
    todos_dir = ws / "todos"
    todos = []
    if todos_dir.is_dir():
        todos = list(todos_dir.glob("*.txt"))

    # Build pool: real todos + one QA sentinel
    pool = list(todos)  # copy
    QA_SENTINEL = "QA"
    if repos:
        pool.append(QA_SENTINEL)

    if not pool:
        return None, None, None

    random.shuffle(pool)
    for pick in pool:
        if pick == QA_SENTINEL:
            repo = random.choice(repos)
            return (
                None,
                (
                    f"QA test $WORKSPACE_DIR/repos/{repo}. "
                    "Read only its documentation (README, CLAUDE.md, "
                    "RULES.md, docs/, Makefile targets, --help output). "
                    "Clone, install, and test every documented feature. "
                    "File bug reports in $WORKSPACE_DIR/todos/ for any "
                    "issues found. Clean up ~/work/ when done."
                ),
                "qa",
            )

        # Real todo file — mv is the concurrency lock
        wip_dir = ws / "wip"
        wip_dir.mkdir(exist_ok=True)
        dest = wip_dir / pick.name
        try:
            content = pick.read_text()
            pick.rename(dest)
        except OSError:
            continue  # another agent grabbed it, try next
        return dest, content, "developer"

    return None, None, None


def max_patches_per_repo(ws: Path) -> int:
    """Count .patch files per subdirectory in merge-queue/, return the max."""
    mq = ws / "merge-queue"
    if not mq.is_dir():
        return 0
    counts = {}
    for patch in mq.rglob("*.patch"):
        repo = patch.parent.name
        counts[repo] = counts.get(repo, 0) + 1
    return max(counts.values()) if counts else 0


def extract_subject(patch: Path) -> str:
    """Extract Subject line from a patch file."""
    try:
        with open(patch) as f:
            for line in f:
                if line.startswith("Subject:"):
                    return re.sub(r"^Subject:\s*\[PATCH[^\]]*\]\s*", "", line).strip()
    except OSError:
        pass
    return "(unknown)"


def stamp_todo_header(ws: Path, todo_name: str):
    """Add X-Todo header to any patches in merge-queue/ that lack it."""
    mq = ws / "merge-queue"
    for patch in mq.rglob("*.patch"):
        if extract_todo(patch) is None:
            content = patch.read_text()
            # Insert X-Todo after the Subject line
            patched = re.sub(
                r"(^Subject: .+\n)",
                rf"\1X-Todo: {todo_name}\n",
                content,
                count=1,
                flags=re.MULTILINE,
            )
            if patched != content:
                patch.write_text(patched)


def extract_todo(patch: Path) -> str | None:
    """Extract X-Todo header from a patch file."""
    try:
        with open(patch) as f:
            for line in f:
                if line.strip() == "":
                    break  # end of headers
                if line.startswith("X-Todo:"):
                    return line.split(":", 1)[1].strip()
    except OSError:
        pass
    return None


# --- Agent management ---


def get_agents() -> list:
    """List running agent names from ~/.mickey/vms/."""
    agents = []
    if not VMS_DIR.is_dir():
        return agents
    for vm_dir in sorted(VMS_DIR.iterdir()):
        if not vm_dir.is_dir():
            continue
        pid_file = vm_dir / "pid"
        if not pid_file.exists():
            continue
        try:
            pid = int(pid_file.read_text().strip())
            os.kill(pid, 0)  # check if alive
            agents.append(vm_dir.name)
        except (ValueError, ProcessLookupError, OSError):
            pass
    return agents


def start_agent(
    name, prompt, ws, model, agent_type="developer", todo_file=None, debug=False
):
    """Start an agent in a background thread. Returns the thread."""
    rules = QA_RULES if agent_type == "qa" else AGENT_RULES

    def run():
        # Write rules and prompt to files on the 9p share so we don't
        # have to pass them through SSH quoting hell.
        tmp_dir = ws / ".mickey-tmp"
        tmp_dir.mkdir(exist_ok=True)
        rules_file = tmp_dir / f"{name}-rules.txt"
        prompt_file = tmp_dir / f"{name}-prompt.txt"
        rules_file.write_text(rules)
        prompt_file.write_text(prompt)

        guest_rules = f"/home/agent/src/.mickey-tmp/{name}-rules.txt"
        guest_prompt = f"/home/agent/src/.mickey-tmp/{name}-prompt.txt"

        # Build a launcher script piped via stdin — no quoting issues
        lines = ["export WORKSPACE_DIR=/home/agent/src"]
        api_key = os.environ.get("ANTHROPIC_API_KEY", "")
        if api_key:
            lines.append(f"export ANTHROPIC_API_KEY={shlex.quote(api_key)}")
        if model:
            lines.append(f"export ANTHROPIC_MODEL={shlex.quote(model)}")
        if todo_file:
            lines.append(f"export TODO_FILE={shlex.quote(todo_file)}")
        lines.append(
            f"exec claude --dangerously-skip-permissions"
            f' --append-system-prompt "$(cat {guest_rules})"'
            f' -p "$(cat {guest_prompt})"'
        )
        script = "\n".join(lines) + "\n"

        cmd = ssh_cmd(name) + ["bash", "-s"]
        if debug:
            print(f"[{name}] script:\n{script}", flush=True)
        try:
            out = None if debug else subprocess.DEVNULL
            err = None if debug else subprocess.DEVNULL
            proc = subprocess.Popen(
                cmd,
                stdin=subprocess.PIPE,
                stdout=out,
                stderr=err,
                start_new_session=True,
            )
            proc.communicate(input=script.encode())
            t.returncode = proc.returncode
        except Exception as e:
            print(f"\r[{name}] error: {e}", flush=True)
            t.returncode = 1

    t = threading.Thread(target=run, daemon=True, name=name)
    t.returncode = None
    t.start()
    return t


# --- Lock/unlock helpers ---


def lock(ws: Path):
    repos_dir = ws / "repos"
    if repos_dir.is_dir():
        subprocess.run(
            ["chmod", "-R", "a-w", str(repos_dir)],
            capture_output=True,
        )


def unlock(ws: Path):
    repos_dir = ws / "repos"
    if repos_dir.is_dir():
        subprocess.run(
            ["chmod", "-R", "u+w", str(repos_dir)],
            capture_output=True,
        )


# --- Commands ---


def cmd_hire(args):
    name = args.name
    ensure_mickey_dir()

    base_img = MICKEY_DIR / "base.qcow2"
    base_vars = MICKEY_DIR / "base-vars.fd"
    if not base_img.exists():
        print(
            "error: base image not found. Run: mickey mkimage",
            file=sys.stderr,
        )
        sys.exit(1)

    vm_dir = VMS_DIR / name
    if vm_dir.exists():
        print(f"error: VM '{name}' already exists.", file=sys.stderr)
        sys.exit(1)
    vm_dir.mkdir()

    # Create CoW overlay disk
    subprocess.run(
        [
            "qemu-img",
            "create",
            "-f",
            "qcow2",
            "-b",
            str(base_img),
            "-F",
            "qcow2",
            str(vm_dir / "disk.qcow2"),
        ],
        check=True,
    )

    # Copy UEFI vars
    if base_vars.exists():
        shutil.copy2(str(base_vars), str(vm_dir / "vars.fd"))
    else:
        # Create blank 64MB vars file
        with open(vm_dir / "vars.fd", "wb") as f:
            f.truncate(64 * 1024 * 1024)

    # Allocate SSH port
    port = allocate_port()
    (vm_dir / "ssh_port").write_text(str(port))

    # Ensure workspace is accessible via 9p (guest UID differs from host)
    ws = workspace()
    mq = ws / "merge-queue"
    mq.mkdir(exist_ok=True)
    os.chmod(str(mq), 0o777)

    # Start VM
    start_vm(name)
    print(f"waiting for VM '{name}' to boot (port {port})...")
    wait_for_ssh(name)
    # Set hostname to agent name so patches use it
    subprocess.run(
        ssh_cmd(name) + ["sudo", "hostnamectl", "set-hostname", name],
        capture_output=True,
    )
    print(f"VM '{name}' is ready.")

    # Interactive claude session for setup
    os.execvp("ssh", ssh_cmd(name, ["-t"]) + ["claude"])


def _join_agents(threads, wip_files, ws):
    """Join all running agent threads and handle their wip files."""
    for n, t in list(threads.items()):
        t.join()
        if n in wip_files and wip_files[n]:
            wip = wip_files.pop(n)
            stamp_todo_header(ws, wip.name)
            has_patch = any(
                extract_todo(p) == wip.name
                for p in (ws / "merge-queue").rglob("*.patch")
            )
            if has_patch:
                print(f"\r{wip.name} has patch in merge-queue")
            elif wip.exists():
                rc = t.returncode
                dest = ws / "todos" / wip.name
                wip.rename(dest)
                if rc and rc != 0:
                    print(f"\r{n} died (exit {rc}), returned {wip.name} to todos/")
                else:
                    print(f"\rreturned {wip.name} to todos/")
            subprocess.run(
                ssh_cmd(n)
                + ["rm -rf ~/work/* && docker system prune -af --volumes 2>/dev/null"],
                capture_output=True,
            )
    threads.clear()


def cmd_whip(args):
    ws = workspace()
    model = args.model

    if args.j is not None and args.j < 1:
        print("\rerror: -j requires a positive integer.", file=sys.stderr)
        sys.exit(1)

    # Determine agents to use — start stopped VMs automatically.
    all_agents = get_agents()
    if not all_agents:
        hired = (
            [d.name for d in sorted(VMS_DIR.iterdir()) if d.is_dir()]
            if VMS_DIR.is_dir()
            else []
        )
        if not hired:
            print("\rno agents found. hire some first: mickey hire <name>")
            return
        for name in hired:
            print(f"\rstarting stopped agent {name}...")
            start_vm(name)
        for name in hired:
            wait_for_ssh(name)
            print(f"\r  {name} ready.")
        all_agents = get_agents()
        if not all_agents:
            print("\rerror: agents failed to start.", file=sys.stderr)
            return

    if args.j is not None:
        if len(all_agents) < args.j:
            print(
                f"\rrequested {args.j} agents but only {len(all_agents)} available.",
                file=sys.stderr,
            )
            sys.exit(1)
        agents = all_agents[: args.j]
    else:
        agents = all_agents

    threads = {}
    wip_files = {}  # agent_name -> wip_path
    last_am = time.monotonic()
    last_guard = 0.0  # force check on first iteration

    lock(ws)
    try:
        while True:
            patches = max_patches_per_repo(ws)
            stale = time.monotonic() - last_am > 900
            if patches >= 2 or (patches > 0 and stale):
                _join_agents(threads, wip_files, ws)
                unlock(ws)
                do_am(ws, push=True)
                lock(ws)
                last_am = time.monotonic()

            # Rate limit guard — check at most every GUARD_POLL_INTERVAL
            if not args.no_guard:
                now = time.monotonic()
                if now - last_guard >= GUARD_POLL_INTERVAL:
                    if check_rate_limit():
                        # Rate limited — join agents, flush patches, poll
                        _join_agents(threads, wip_files, ws)
                        unlock(ws)
                        do_am(ws, push=True)
                        last_am = time.monotonic()
                        print("\rguard: waiting for rate limit to reset...")
                        while True:
                            time.sleep(GUARD_POLL_INTERVAL)
                            if not check_rate_limit():
                                break
                        print("\rguard: rate limit cleared, resuming.")
                        lock(ws)
                    last_guard = time.monotonic()

            for n in agents:
                if n in threads and threads[n].is_alive():
                    continue
                # Agent finished — stamp X-Todo into any patches it produced,
                # then return wip to todos if no patch was produced.
                if n in wip_files and wip_files[n]:
                    wip = wip_files.pop(n)
                    # Stamp X-Todo header into new patches missing it
                    stamp_todo_header(ws, wip.name)
                    has_patch = any(
                        extract_todo(p) == wip.name
                        for p in (ws / "merge-queue").rglob("*.patch")
                    )
                    if has_patch:
                        print(f"\r{wip.name} has patch in merge-queue")
                    elif wip.exists():
                        rc = threads[n].returncode if n in threads else None
                        dest = ws / "todos" / wip.name
                        wip.rename(dest)
                        if rc and rc != 0:
                            print(
                                f"\r{n} died (exit {rc}), returned {wip.name} to todos/"
                            )
                        else:
                            print(f"\rreturned {wip.name} to todos/")
                    # Clean workspace and docker images
                    subprocess.run(
                        ssh_cmd(n)
                        + [
                            "rm -rf ~/work/*"
                            " && docker system prune -af --volumes 2>/dev/null"
                        ],
                        capture_output=True,
                    )
                wip, prompt, agent_type = pick_task(ws)
                if prompt:
                    wip_files[n] = wip
                    print(f"\rsending {n} to work...")
                    threads[n] = start_agent(
                        n,
                        prompt,
                        ws,
                        model,
                        agent_type,
                        todo_file=wip.name if wip else None,
                        debug=args.debug,
                    )

            time.sleep(25)
    finally:
        unlock(ws)


