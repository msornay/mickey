def cmd_reset(args):
    ws = workspace()
    wip_dir = ws / "wip"
    mq_dir = ws / "merge-queue"

    def count_files(d):
        if not d.is_dir():
            return 0
        return sum(1 for f in d.rglob("*") if f.is_file() and f.name != ".DS_Store")

    wip_count = count_files(wip_dir)
    mq_count = count_files(mq_dir)

    todos_dir = ws / "todos"

    agents = get_agents()

    print("\rthis will:")
    if agents:
        print(f"\r  kill claude in {len(agents)} agent(s): {', '.join(agents)}")
    print(f"\r  move {wip_count} file(s) from {wip_dir} back to {todos_dir}")
    print(f"\r  delete {mq_count} file(s) in {mq_dir}")
    answer = input("continue? [y/N] ")
    if answer.strip().lower() != "y":
        print("\raborted.")
        sys.exit(1)

    for name in agents:
        try:
            subprocess.run(
                ssh_cmd(name) + ["pkill", "-f", "claude"],
                capture_output=True,
                timeout=5,
            )
        except (OSError, subprocess.TimeoutExpired):
            pass

    if wip_dir.is_dir():
        todos_dir.mkdir(exist_ok=True)
        for f in wip_dir.iterdir():
            if f.is_file() and f.name != ".DS_Store":
                f.rename(todos_dir / f.name)

    if mq_dir.is_dir():
        for f in mq_dir.rglob("*"):
            if f.is_file() and f.name != ".DS_Store":
                f.unlink()
        # Clean empty subdirs
        for d in sorted(mq_dir.rglob("*"), reverse=True):
            if d.is_dir():
                try:
                    d.rmdir()
                except OSError:
                    pass

    print("\rdone.")


def cmd_mkimage(args):
    """Create the golden base image for QEMU VMs."""
    ensure_mickey_dir()
    base_img = MICKEY_DIR / "base.qcow2"
    base_vars = MICKEY_DIR / "base-vars.fd"

    if base_img.exists() and not args.force:
        print(
            "base image already exists. Use --force to rebuild.",
            file=sys.stderr,
        )
        sys.exit(1)

    edk2 = find_edk2_code()

    # Download Ubuntu 24.04 cloud image if needed
    dl_path = MICKEY_DIR / "noble-server-cloudimg-arm64.img"
    if not dl_path.exists():
        print("downloading Ubuntu 24.04 arm64 cloud image...")
        subprocess.run(
            [
                "curl",
                "-L",
                "-o",
                str(dl_path),
                "https://cloud-images.ubuntu.com/noble/current/"
                "noble-server-cloudimg-arm64.img",
            ],
            check=True,
        )

    # Create base image from cloud image
    print("creating base image...")
    shutil.copy2(str(dl_path), str(base_img))
    subprocess.run(
        ["qemu-img", "resize", str(base_img), "40G"],
        check=True,
    )

    # Create UEFI vars template
    edk2_vars_src = Path(edk2).parent / "edk2-arm-vars.fd"
    if edk2_vars_src.exists():
        shutil.copy2(str(edk2_vars_src), str(base_vars))
    else:
        # Create blank 64MB vars file
        with open(base_vars, "wb") as f:
            f.truncate(64 * 1024 * 1024)

    # Write cloud-init config
    ci_dir = MICKEY_DIR / "cloud-init"
    ci_dir.mkdir(exist_ok=True)

    pub_key = SSH_KEY.with_suffix(".pub").read_text().strip()

    (ci_dir / "meta-data").write_text(
        "instance-id: mickey-base\nlocal-hostname: mickey\n"
    )
    (ci_dir / "user-data").write_text(
        "#cloud-config\n"
        "users:\n"
        "  - name: agent\n"
        "    sudo: ALL=(ALL) NOPASSWD:ALL\n"
        "    shell: /bin/bash\n"
        "    ssh_authorized_keys:\n"
        f"      - {pub_key}\n"
        "\n"
        "package_update: true\n"
        "packages:\n"
        "  - docker.io\n"
        "  - docker-compose-v2\n"
        "  - git\n"
        "  - build-essential\n"
        "  - curl\n"
        "\n"
        "runcmd:\n"
        "  - usermod -aG docker agent\n"
        "  - systemctl enable docker\n"
        "  - systemctl start docker\n"
        "  - |\n"
        "    curl -fsSL https://deb.nodesource.com/setup_22.x"
        " | bash -\n"
        "    apt-get install -y nodejs\n"
        "    npm install -g @anthropic-ai/claude-code\n"
        "  - mkdir -p /home/agent/src /home/agent/work\n"
        "  - chown -R agent:agent /home/agent\n"
        "  - echo 'workspace /home/agent/src 9p"
        " _netdev,trans=virtio,msize=524288 0 0'"
        " >> /etc/fstab\n"
        "  - cloud-init clean --logs\n"
        "  - poweroff\n"
    )

    # Create cloud-init ISO
    ci_iso = MICKEY_DIR / "cloud-init.iso"
    subprocess.run(
        [
            "mkisofs",
            "-output",
            str(ci_iso),
            "-volid",
            "cidata",
            "-joliet",
            "-rock",
            str(ci_dir / "user-data"),
            str(ci_dir / "meta-data"),
        ],
        check=True,
    )

    # Boot VM with cloud-init to provision (blocks until poweroff)
    print("provisioning base image (this takes a few minutes)...")
    result = subprocess.run(
        [
            "qemu-system-aarch64",
            "-accel",
            "hvf",
            "-cpu",
            "host",
            "-M",
            "virt,highmem=on",
            "-m",
            "4096",
            "-smp",
            "2",
            "-drive",
            f"file={edk2},if=pflash,format=raw,readonly=on",
            "-drive",
            f"file={base_vars},if=pflash,format=raw",
            "-drive",
            f"if=virtio,file={base_img},format=qcow2",
            "-drive",
            f"file={ci_iso},if=virtio,format=raw,readonly=on",
            "-netdev",
            "user,id=net0",
            "-device",
            "virtio-net-pci,netdev=net0",
            "-nographic",
        ],
    )
    if result.returncode != 0:
        print("error: provisioning failed.", file=sys.stderr)
        sys.exit(1)

    # Clean up cloud-init artifacts
    ci_iso.unlink(missing_ok=True)
    shutil.rmtree(ci_dir, ignore_errors=True)

    print(f"base image ready: {base_img}")


def cmd_cleanup(args):
    """Remove orphan VM directories whose processes are dead."""
    if not VMS_DIR.is_dir():
        print("no VMs directory found.")
        return
    cleaned = 0
    for vm_dir in sorted(VMS_DIR.iterdir()):
        if not vm_dir.is_dir():
            continue
        pid_file = vm_dir / "pid"
        if not pid_file.exists():
            shutil.rmtree(vm_dir)
            print(f"removed stale directory: {vm_dir.name}")
            cleaned += 1
            continue
        try:
            pid = int(pid_file.read_text().strip())
            os.kill(pid, 0)
        except (ValueError, ProcessLookupError, OSError):
            shutil.rmtree(vm_dir)
            print(f"removed orphan: {vm_dir.name}")
            cleaned += 1
    if cleaned == 0:
        print("no orphans found.")


def main():
    parser = argparse.ArgumentParser(
        prog="mickey",
        description="AI agent orchestrator",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
Commands:
  hire     <name>                          Create agent VM (interactive)
  whip     [--model <m>] [-j N] [--no-guard] Send agents to work
  sh       <name>                          Shell into agent VM
  ls                                       List agent VMs
  fire     <name>                          Remove agent VM
  am       [--push]                        Apply patches from merge-queue/
  status                                   Show todos, wip, queued patches
  reset                                    Clear wip/ and merge-queue/
  mkimage  [--force]                       Build golden base VM image
  cleanup                                  Remove orphan VM directories
""",
    )
    sub = parser.add_subparsers(dest="command")

    p_hire = sub.add_parser("hire", help="Create agent VM")
    p_hire.add_argument("name")
    p_hire.set_defaults(func=cmd_hire)

    p_whip = sub.add_parser("whip", help="Send agents to work")
    p_whip.add_argument("--model", default=None)
    p_whip.add_argument("-j", type=int, default=None)
    p_whip.add_argument("--debug", action="store_true", help="Show agent stdout/stderr")
    p_whip.add_argument(
        "--no-guard", action="store_true", help="Disable rate limit guard"
    )
    p_whip.set_defaults(func=cmd_whip)

    p_sh = sub.add_parser("sh", help="Shell into agent VM")
    p_sh.add_argument("name")
    p_sh.set_defaults(func=cmd_sh)

    p_ls = sub.add_parser("ls", help="List agent VMs")
    p_ls.set_defaults(func=cmd_ls)

    p_fire = sub.add_parser("fire", help="Remove agent VM")
    p_fire.add_argument("name")
    p_fire.set_defaults(func=cmd_fire)

    p_am = sub.add_parser("am", help="Apply patches from merge-queue/")
    p_am.add_argument("--push", action="store_true")
    p_am.set_defaults(func=cmd_am)

    p_status = sub.add_parser("status", help="Show status")
    p_status.set_defaults(func=cmd_status)

    p_reset = sub.add_parser("reset", help="Clear wip/ and merge-queue/")
    p_reset.set_defaults(func=cmd_reset)

    p_mkimage = sub.add_parser("mkimage", help="Build golden base VM image")
    p_mkimage.add_argument("--force", action="store_true")
    p_mkimage.set_defaults(func=cmd_mkimage)

    p_cleanup = sub.add_parser("cleanup", help="Remove orphan VM directories")
    p_cleanup.set_defaults(func=cmd_cleanup)

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    args.func(args)


if __name__ == "__main__":
    main()
