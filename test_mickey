# ===== Rate limit guard tests =====


def test_check_rate_limit_ok():
    """check_rate_limit returns False when under thresholds."""
    mickey = _import_mickey()
    with patch.object(mickey, "_get_oauth_token", return_value="tok"), \
         patch.object(mickey, "_fetch_rate_limits", return_value=(0.30, 0.40)):
        assert mickey.check_rate_limit() is False


def test_check_rate_limit_5h_exceeded():
    """check_rate_limit returns True when 5h utilization exceeds threshold."""
    mickey = _import_mickey()
    with patch.object(mickey, "_get_oauth_token", return_value="tok"), \
         patch.object(mickey, "_fetch_rate_limits", return_value=(0.85, 0.40)):
        assert mickey.check_rate_limit() is True


def test_check_rate_limit_7d_exceeded():
    """check_rate_limit returns True when 7d utilization exceeds threshold."""
    mickey = _import_mickey()
