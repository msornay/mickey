def test_get_oauth_token_parses_keychain():
    """_get_oauth_token extracts access token from keychain JSON."""
    mickey = _import_mickey()
    import json
    creds = json.dumps({"claudeAiOauth": {"accessToken": "my-tok"}})
    with patch("subprocess.check_output", return_value=creds):
        assert mickey._get_oauth_token() == "my-tok"


def test_get_oauth_token_missing_oauth_raises():
    """_get_oauth_token raises RuntimeError when JSON lacks expected key."""
    mickey = _import_mickey()
    import json
    with patch("subprocess.check_output",
               return_value=json.dumps({"other": "stuff"})):
        try:
            mickey._get_oauth_token()
            assert False, "should have raised"
        except RuntimeError as e:
            assert "missing" in str(e).lower()


def test_whip_no_guard_flag():
    """--no-guard flag is accepted by whip parser."""
    r = run([str(MICKEY), "whip", "--no-guard", "-j", "0"])
    # -j 0 should still fail, but --no-guard should be parsed
    assert r.returncode != 0
    assert "positive" in r.stderr.lower() or r.returncode != 0


if __name__ == "__main__":
    # Simple test runner fallback if pytest isn't available
    import traceback
    tests = [
        v for k, v in sorted(globals().items())
        if k.startswith("test_") and callable(v)
    ]
    passed = failed = 0
    for test in tests:
        try:
            test()
            passed += 1
            print(f"ok   - {test.__name__}")
        except Exception:
            failed += 1
            print(f"FAIL - {test.__name__}")
            traceback.print_exc()
    print(f"\n{passed + failed} tests, {passed} passed, {failed} failed")
    raise SystemExit(1 if failed else 0)
