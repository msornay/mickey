        env = make_workspace(ws)
        Path(f"{ws}/todos/test-task.txt").write_text("Fix the widget")
        r = run([str(MICKEY), "status"], env=env)
        assert "test-task" in r.stdout
        assert "Fix the widget" in r.stdout


